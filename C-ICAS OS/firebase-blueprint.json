{
  "entities": {
    "User": {
      "title": "User Profile",
      "description": "Pracownik, Kierownik lub Admin autoryzujący się w systemie.",
      "type": "object",
      "properties": {
        "email": { "type": "string" },
        "displayName": { "type": "string" },
        "photoURL": { "type": "string" },
        "mfaEnabled": { "type": "boolean" },
        "biometricEnabled": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "timestamp" },
        "lastLoginAt": { "type": "string", "format": "timestamp" }
      },
      "required": ["email", "createdAt"]
    },
    "Tenant": {
