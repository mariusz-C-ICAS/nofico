        "icon": { "type": "string" },
        "path": { "type": "string" },
        "color": { "type": "string" },
        "isActive": { "type": "boolean" },
        "updatedAt": { "type": "string", "format": "timestamp" }
      },
      "required": ["key", "name", "isActive"]
