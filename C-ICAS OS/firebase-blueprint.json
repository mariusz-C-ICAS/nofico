        "tenantId": { "type": "string" },
        "name": { "type": "string" },
        "type": { "type": "string" },
        "classification": { "type": "string" },
        "date": { "type": "string" },
        "status": { "type": "string" },
        "size": { "type": "string" },
        "sha256": { "type": "string" },
        "summary": { "type": "string" },
        "machineText": { "type": "string" },
        "handwrittenText": { "type": "string" },
        "stamps": { "type": "string" },
