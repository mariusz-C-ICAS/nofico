rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Global Safety Net — Admin: full access; everyone else: deny by default (specific rules below override)
    match /{document=**} {
      allow read, write: if isAdmin();
      allow read, write: if false;
    }

    // ----- Primitives -----
    function isSignedIn() {
      return request.auth != null;
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function isAdmin() {
      return isSignedIn() && 
        (request.auth.token.email_verified == true) &&
        ((request.auth.token.email != null) && 
         request.auth.token.email.lower() in ['mariusz.czaja@gmail.com', 'mariusz@c-icas.gg', 'lena@c-icas.gg']);
    }

    // ── Flat tenantMemberships model ─────────────────────────────────────────
    // OWNER doc: ID = tenantId (setDoc). Regular members: auto-ID + tenantId field.
    // We can only efficiently check the OWNER doc by ID. Regular member access
    // is enforced via the tenant ownerId fallback for now.

    function isMemberOf(tenantId) {
      return isSignedIn() && (
        // OWNER: doc ID = tenantId
        (exists(/databases/$(database)/documents/tenantMemberships/$(tenantId)) &&
         get(/databases/$(database)/documents/tenantMemberships/$(tenantId)).data.userId == request.auth.uid) ||
        // Fallback: user is listed as ownerId on the tenant doc
        (exists(/databases/$(database)/documents/tenants/$(tenantId)) &&
         get(/databases/$(database)/documents/tenants/$(tenantId)).data.ownerId == request.auth.uid)
      );
    }

    function getMembership(tenantId) {
      // Returns the OWNER membership doc (doc ID = tenantId)
      return get(/databases/$(database)/documents/tenantMemberships/$(tenantId)).data;
    }

    function hasRole(tenantId, role) {
      return isMemberOf(tenantId) && (
        getMembership(tenantId).get('role', '') == role ||
        getMembership(tenantId).get('role', '') == 'OWNER'
      );
    }

    function isTenantAdmin(tenantId) {
      return hasRole(tenantId, 'ADMIN') || hasRole(tenantId, 'OWNER') || isAdmin();
    }

    // Bootstrap: during onboarding, user creates OWNER membership before any doc exists
    function isOnboardingOwnerMembership(membershipId) {
      return isSignedIn() &&
        incoming().userId == request.auth.uid &&
        incoming().role == 'OWNER' &&
        incoming().get('status', 'ACTIVE') == 'ACTIVE' &&
        incoming().get('tenantId', membershipId) == membershipId &&
        exists(/databases/$(database)/documents/tenants/$(membershipId)) &&
        get(/databases/$(database)/documents/tenants/$(membershipId)).data.ownerId == request.auth.uid;
    }

    // Bootstrap: tenant owner creates the first company before membership is resolvable
    function isTenantOwnerBootstrap(tenantId) {
      return isSignedIn() &&
        exists(/databases/$(database)/documents/tenants/$(tenantId)) &&
        get(/databases/$(database)/documents/tenants/$(tenantId)).data.ownerId == request.auth.uid;
    }

    // ----- Entity Validation Blueprints -----

    function isValidEmployee(data) {
      return data.keys().hasAll(['firstName', 'lastName', 'contractType', 'tenantId', 'createdAt']) &&
        data.firstName is string && data.firstName.size() <= 100 &&
        data.lastName is string && data.lastName.size() <= 100 &&
        (data.get('email', '') is string && data.get('email', '').size() <= 200) &&
        (data.get('pesel', '') is string && data.get('pesel', '').size() <= 20) &&
        (data.get('nip', '') is string && data.get('nip', '').size() <= 20) &&
        (data.get('nationality', 'PL') is string) &&
        (data.get('role', '') is string) &&
        (data.get('status', 'INCOMPLETE') in ['ACTIVE', 'INCOMPLETE', 'TERMINATED']) &&
        (data.get('salaryType', 'GROSS') in ['GROSS', 'NET']) &&
        (data.get('tenantId', '') is string) &&
        data.createdAt == request.time;
    }

    function isValidHRSettings(data) {
      return data.keys().hasAll(['aiLicenseTier']) &&
        data.aiLicenseTier in ['BASIC', 'PRO', 'ENTERPRISE'] &&
        (data.get('enableZusTaxes', true) is bool) &&
        (data.get('zusEmerytalna', 0) is number);
    }

    function isValidAuditLog(data) {
      return data.keys().hasAll(['tenantId', 'entityId', 'collection', 'action', 'userId', 'createdAt']) &&
        data.tenantId is string &&
        data.entityId is string &&
        data.collection is string &&
        data.action in ['create', 'update', 'delete'] &&
        data.userId is string &&
        data.createdAt == request.time;
    }

    function isValidScanDocument(data) {
      return data.keys().hasAll(['tenantId', 'name', 'summary', 'createdAt']) &&
        data.tenantId is string &&
        data.name is string &&
        data.summary is string &&
        data.createdAt == request.time;
    }

    // ── Workflow Module validators ────────────────────────────────────────────

    // All 49 DocumentType values (2026-05-16)
    function isValidDocType(t) {
      return t in [
        'OUT_OF_POCKET', 'VENDOR_INVOICE', 'CONTRACT', 'TIMESHEET', 'PURCHASE_ORDER',
        'TRAVEL_EXPENSE', 'PROJECT_DELIVERY', 'DAMAGE_CLAIM', 'BHP_INCIDENT', 'VEHICLE_INCIDENT',
        'IT_INCIDENT', 'ASSET_HANDOVER', 'EXPENSE_ADVANCE', 'QUALITY_NCR', 'SUBCONTRACTOR_APPROVAL',
        'LEAVE_REQUEST', 'CUSTOM',
        'CREDIT_NOTE', 'BUDGET_REQUEST', 'WRITE_OFF', 'TAX_DOCUMENT',
        'RFQ', 'BID_EVALUATION', 'GOODS_RECEIPT', 'GOODS_ISSUE', 'RETURN_MERCHANDISE',
        'NDA', 'GDPR_REQUEST', 'POLICY_EXCEPTION', 'REGULATORY_BREACH', 'AUDIT_FINDING', 'WHISTLEBLOWER',
        'SALES_ORDER', 'QUOTE_APPROVAL', 'CUSTOMER_COMPLAINT', 'DISCOUNT_APPROVAL',
        'CHANGE_REQUEST', 'RISK_REGISTER', 'PROJECT_CLOSURE',
        'PATIENT_INCIDENT', 'MEDICATION_ERROR',
        'PRODUCTION_ORDER', 'ENGINEERING_CHANGE', 'CALIBRATION_RECORD',
        'INSPECTION_REPORT', 'TRANSPORT_ORDER', 'CUSTOMS_DECLARATION', 'INSURANCE_CLAIM', 'LEASE_AGREEMENT'
      ];
    }

    // All DocumentStatus values (including 4 new statuses)
    function isValidDocStatus(s) {
      return s in [
        'DRAFT', 'SUBMITTED', 'PENDING_APPROVAL', 'APPROVED', 'REJECTED',
        'KSEF_VERIFIED', 'BOOKED', 'PENDING_SETTLEMENT', 'SETTLED', 'ARCHIVED',
        'BILLING_READY', 'MARKETING_REVIEW', 'MARKETING_APPROVED',
        'CLAIM_FILED', 'CLAIM_REJECTED', 'CLAIM_APPEALED', 'CLAIM_APPROVED',
        'BHP_DISPATCHED', 'BHP_CLOSED', 'NCR_OPEN', 'NCR_VERIFIED', 'ADVANCE_ISSUED',
        'UNDER_INVESTIGATION', 'COMPLAINT_RESOLVED', 'GOODS_RECEIVED', 'QUOTE_SENT'
      ];
    }

    // WORM-protected document types — extra immutability enforcement
    function isSensitiveDocType(t) {
      return t in ['PATIENT_INCIDENT', 'WHISTLEBLOWER', 'REGULATORY_BREACH', 'GDPR_REQUEST', 'AUDIT_FINDING'];
    }

    function isValidDocumentInstance(data) {
      return data.keys().hasAll(['tenantId', 'type', 'status', 'submittedBy', 'submittedByEmail', 'metadata', 'createdAt']) &&
        data.tenantId is string &&
        isValidDocType(data.type) &&
        isValidDocStatus(data.status) &&
        data.submittedBy == request.auth.uid &&
        data.submittedByEmail is string &&
        data.metadata is map &&
        data.createdAt == request.time;
    }

    function isValidDocumentInstanceUpdate(data, existing) {
      return data.tenantId == existing.tenantId &&
        data.submittedBy == existing.submittedBy &&
        data.type == existing.type &&
        data.createdAt == existing.createdAt &&
        data.diff(existing).affectedKeys().hasOnly(['status', 'currentStepId', 'assignedTo', 'updatedAt', 'metadata', 'attachments', 'companyId']) &&
        isValidDocStatus(data.status) &&
        // WORM: sensitive docs — once beyond SUBMITTED, metadata cannot change
        (!isSensitiveDocType(existing.type) ||
          existing.status == 'DRAFT' ||
          !data.diff(existing).affectedKeys().hasAny(['metadata']));
    }

    // GoBD / GoBS: workflowSteps are strictly append-only
    function isValidWorkflowStep(data) {
      return data.keys().hasAll(['documentInstanceId', 'tenantId', 'action', 'actorId', 'actorEmail', 'previousStatus', 'newStatus', 'timestamp']) &&
        data.documentInstanceId is string &&
        data.tenantId is string &&
        data.action in ['CREATE', 'SUBMIT', 'APPROVE', 'REJECT', 'REQUEST_CHANGES', 'VERIFY', 'BOOK', 'SETTLE', 'ARCHIVE', 'RESUBMIT', 'CANCEL'] &&
        data.actorId == request.auth.uid &&
        data.actorEmail is string &&
        data.previousStatus is string &&
        data.newStatus is string &&
        data.timestamp == request.time;
    }

    function isValidWorkflowTemplate(data) {
      return data.keys().hasAll(['tenantId', 'documentType', 'name', 'steps', 'isDefault', 'createdBy', 'createdAt']) &&
        data.tenantId is string &&
        isValidDocType(data.documentType) &&
        data.name is string && data.name.size() <= 200 &&
        data.steps is list &&
        data.isDefault is bool &&
        data.createdBy is string &&
        data.createdAt == request.time;
    }

    function isValidWorkflowNotification(data) {
      return data.keys().hasAll(['tenantId', 'recipientId', 'documentInstanceId', 'type', 'message', 'read', 'createdAt']) &&
        data.tenantId is string &&
        data.recipientId is string &&
        data.documentInstanceId is string &&
        data.type in [
          'APPROVAL_REQUIRED', 'DOCUMENT_APPROVED', 'DOCUMENT_REJECTED', 'DOCUMENT_SETTLED',
          'KSEF_VERIFIED', 'STEP_TIMEOUT', 'DOCUMENT_CANCELLED', 'CHANGES_REQUESTED',
          'COMPLAINT_RESOLVED', 'UNDER_INVESTIGATION', 'GOODS_RECEIVED'
        ] &&
        data.message is string &&
        data.read is bool &&
        data.createdAt == request.time;
    }

    // ── Multi-Company validators ──────────────────────────────────────────────

    function isValidCompany(data) {
      return data.keys().hasAll(['tenantId', 'name', 'isActive']) &&
        data.tenantId is string &&
        data.name is string && data.name.size() > 0 && data.name.size() <= 200 &&
        data.isActive is bool &&
        (data.get('nip', '') is string && data.get('nip', '').size() <= 15) &&
        (data.get('regon', '') is string && data.get('regon', '').size() <= 14) &&
        (data.get('industry', '') is string && data.get('industry', '').size() <= 100) &&
        (data.get('address', {}) is map);
    }

    function isValidCompanyUpdate(data, existing) {
      return data.tenantId == existing.tenantId &&
        data.diff(existing).affectedKeys().hasOnly(['name', 'nip', 'regon', 'address', 'industry', 'isActive', 'phone', 'email', 'website', 'updatedAt']);
    }

    function isValidTenantMembershipFlat(data) {
      return data.keys().hasAll(['tenantId', 'email', 'role']) &&
        data.tenantId is string &&
        data.email is string && data.email.size() <= 200 &&
        data.role in ['OWNER', 'ADMIN', 'MANAGER', 'USER', 'EMPLOYEE', 'VIEWER'] &&
        (data.get('userId', '') is string) &&
        (data.get('displayName', '') is string) &&
        (data.get('status', 'INVITED') in ['ACTIVE', 'INVITED', 'SUSPENDED', 'PENDING']);
    }

    // A user can act on a document if they submitted it or are assigned to it
    function isDocumentActor(tenantId, docData) {
      return docData.submittedBy == request.auth.uid ||
             docData.get('assignedTo', []).hasAny([request.auth.uid]) ||
             hasRole(tenantId, 'manager') ||
             hasRole(tenantId, 'accountant') ||
             hasRole(tenantId, 'hr') ||
             isTenantAdmin(tenantId);
    }

    function isValidScanDocumentVersion(data) {
      return data.keys().hasAll(['version', 'createdAt']) &&
        data.version is number &&
        data.createdAt == request.time;
    }

    function isValidCustomer(data) {
      return data.keys().hasAll(['tenantId', 'name', 'status', 'createdAt']) &&
        data.tenantId is string &&
        data.name is string && data.name.size() <= 200 &&
        data.status in ['active', 'prospect', 'blocked'] &&
        data.createdAt == request.time;
    }

    function isValidDeal(data) {
      return data.keys().hasAll(['tenantId', 'title', 'customerId', 'stage', 'createdAt']) &&
        data.tenantId is string &&
        data.title is string && data.title.size() <= 200 &&
        data.customerId is string &&
        data.stage in ['lead', 'meeting', 'quote', 'negotiation', 'closed_won', 'closed_lost'] &&
        data.createdAt == request.time;
    }

    function isValidQuote(data) {
      return data.keys().hasAll(['tenantId', 'dealId', 'number', 'status', 'createdAt']) &&
        data.tenantId is string &&
        data.dealId is string &&
        data.number is string &&
        data.status in ['draft', 'sent', 'accepted', 'expired'] &&
        data.createdAt == request.time;
    }

    function isValidUser(data) {
      return data.keys().hasAll(['email', 'createdAt']) &&
        data.email is string && data.email.size() <= 200 &&
        (data.get('displayName', '') is string && data.get('displayName', '').size() <= 100) &&
        (data.get('photoURL', '') is string && data.get('photoURL', '').size() <= 500) &&
        (data.get('mfaEnabled', false) is bool) &&
        (data.get('biometricEnabled', false) is bool) &&
        (data.get('activeTenantId', '') is string) &&
        data.createdAt == request.time &&
        (data.get('lastLoginAt', request.time) == request.time);
    }

    function isValidTenant(data) {
      return data.keys().hasAll(['nip', 'name', 'country', 'createdAt', 'ownerId']) &&
        data.nip is string && data.nip.size() >= 9 && data.nip.size() <= 15 &&
        data.name is string && data.name.size() > 0 && data.name.size() <= 200 &&
        (data.get('legalForm', '') is string && data.get('legalForm', '').size() <= 100) &&
        (data.get('vatNumber', '') is string && data.get('vatNumber', '').size() <= 50) &&
        data.country is string && data.country.size() == 2 &&
        data.ownerId == request.auth.uid &&
        data.createdAt == request.time &&
        (data.get('activeModules', []) is list) &&
        (data.get('settings', {}) is map);
    }

    function isValidTenantMembership(data) {
      return data.keys().hasAll(['roleId', 'status', 'joinedAt']) &&
        data.roleId is string && data.roleId.size() <= 50 &&
        data.status in ['active', 'suspended', 'left'] &&
        data.joinedAt == request.time &&
        (data.get('invitedBy', '') is string && data.get('invitedBy', '').size() <= 128) &&
        (data.get('attributes', {}) is map);
    }

    function isValidTenantInvitation(data) {
      return data.keys().hasAll(['email', 'roleId', 'token', 'expiresAt', 'status']) &&
        data.email is string && data.email.size() <= 200 &&
        data.roleId is string && data.roleId.size() <= 50 &&
        data.token is string && data.token.size() >= 32 && data.token.size() <= 128 &&
        data.expiresAt is timestamp &&
        data.status in ['pending', 'accepted', 'expired'];
    }

    function isValidSubscription(data) {
      return data.keys().hasAll(['customerId', 'planId', 'status', 'createdAt']) &&
        data.customerId is string && data.customerId.size() <= 128 &&
        data.planId is string && data.planId.size() <= 100 &&
        data.status in ['active', 'canceled', 'past_due', 'trialing'] &&
        data.createdAt == request.time;
    }

    function isValidPaymentTransaction(data) {
      return data.keys().hasAll(['amount', 'currency', 'status', 'provider', 'createdAt']) &&
        data.amount is number &&
        data.currency is string && data.currency.size() == 3 &&
        data.status in ['pending', 'completed', 'failed', 'refunded'] &&
        data.provider in ['stripe', 'payu', 'p24', 'tpay', 'blik'] &&
        data.createdAt == request.time;
    }

    function isValidRiskAssessment(data) {
      return data.keys().hasAll(['title', 'category', 'riskLevel', 'status', 'createdAt']) &&
        data.title is string && data.title.size() <= 200 &&
        data.category in ['DPIA', 'NIS2', 'AI_ACT', 'GENERAL'] &&
        data.riskLevel is number &&
        data.status in ['draft', 'final', 'review'] &&
        data.createdAt == request.time;
    }

    function isValidOAuthSecret(data) {
      return data.keys().hasAll(['tenantId', 'provider', 'encryptedToken', 'createdAt']) &&
        data.tenantId is string &&
        data.provider is string &&
        data.encryptedToken is string &&
        data.createdAt == request.time;
    }

    function isValidCrossTenantTransaction(data) {
      return data.keys().hasAll(['sourceTenantId', 'targetTenantId', 'amount', 'status', 'createdAt']) &&
        data.sourceTenantId is string &&
        data.targetTenantId is string &&
        data.amount is number &&
        data.status in ['draft', 'pending', 'approved', 'rejected', 'executed'] &&
        data.createdAt == request.time;
    }

    function isValidTPDocument(data) {
      return data.keys().hasAll(['tenantId', 'title', 'period', 'status', 'createdAt']) &&
        data.tenantId is string &&
        data.title is string &&
        data.period is string &&
        data.status in ['draft', 'final'] &&
        data.createdAt == request.time;
    }

    function isValidIntegration(data) {
      return data.keys().hasAll(['tenantId', 'providerId', 'status', 'createdAt']) &&
        data.tenantId is string &&
        data.providerId is string &&
        data.status in ['connected', 'disconnected', 'error', 'pending'] &&
        data.createdAt == request.time;
    }
 
    function isValidAIConversation(data) {
      return data.keys().hasAll(['userId', 'tenantId', 'status', 'createdAt']) &&
        data.userId == request.auth.uid &&
        data.tenantId is string &&
        data.status in ['active', 'archived'] &&
        data.createdAt == request.time;
    }

    function isValidTransactionCategory(data) {
      return data.keys().hasAll(['createdByTenantId', 'name', 'icon', 'color', 'createdAt']) &&
             data.createdByTenantId is string &&
             data.name is string &&
             data.icon is string &&
             data.color is string &&
             data.createdAt == request.time;
    }

    function isComplianceManager(tenantId) {
      return hasRole(tenantId, 'compliance_manager') || isTenantAdmin(tenantId);
    }

    function isSafetyManager(tenantId) {
      return hasRole(tenantId, 'safety_manager') || isComplianceManager(tenantId);
    }

    function isValidAuditFormTemplate(data) {
      return data.keys().hasAll(['tenantId', 'moduleType', 'languageMode', 'title', 'schema', 'retentionDays', 'autoDestruct', 'isActive', 'createdAt']) &&
        data.tenantId is string &&
        data.moduleType is string &&
        data.languageMode is string &&
        data.title is map &&
        data.schema is list &&
        data.retentionDays is number &&
        data.autoDestruct is bool &&
        data.isActive is bool &&
        data.createdAt == request.time;
    }

    function isValidAuditFormSubmission(data) {
      return data.keys().hasAll(['tenantId', 'formTemplateId', 'submittedByUserId', 'data', 'status', 'createdAt']) &&
        data.tenantId is string &&
        data.formTemplateId is string &&
        data.submittedByUserId is string &&
        data.data is map &&
        data.status is string &&
        data.createdAt == request.time;
    }

    function isValidBusinessProcess(data) {
      return data.keys().hasAll(['tenantId', 'name', 'level', 'createdAt']) &&
        data.tenantId is string &&
        data.name is string &&
        data.level is string &&
        data.createdAt == request.time;
    }

    function isValidAiSystem(data) {
      return data.keys().hasAll(['tenantId', 'name', 'riskClassification', 'createdAt']) &&
        data.tenantId is string &&
        data.name is string &&
        data.riskClassification is string &&
        data.createdAt == request.time;
    }

    function isValidAIConversationAudit(data) {
      return data.keys().hasAll(['conversationId', 'userId', 'prompt', 'response', 'timestamp']) &&
        data.conversationId is string &&
        data.userId == request.auth.uid &&
        data.prompt is string &&
        data.response is string &&
        data.timestamp == request.time;
    }

    // ── Onboarding validators ────────────────────────────────────────────────

    // Relaxed tenant create for onboarding — NIP/country optional (filled in later)
    function isValidOnboardingTenant(data) {
      return data.keys().hasAll(['name', 'ownerId', 'plan', 'createdAt']) &&
        data.name is string && data.name.size() > 0 && data.name.size() <= 200 &&
        data.ownerId == request.auth.uid &&
        data.plan in ['trial', 'starter', 'pro', 'enterprise'] &&
        data.createdAt == request.time &&
        (data.get('nip', '') is string && data.get('nip', '').size() <= 15) &&
        (data.get('industry', '') is string && data.get('industry', '').size() <= 100) &&
        (data.get('onboarding', {}) is map);
    }

    function isValidHrDepartment(data) {
      return data.keys().hasAll(['name', 'type', 'tenantId', 'createdAt']) &&
        data.name is string && data.name.size() > 0 && data.name.size() <= 200 &&
        data.type in ['DEPARTMENT', 'DIVISION', 'TEAM', 'LOCATION'] &&
        data.tenantId is string &&
        data.createdAt == request.time;
    }

    // ----- Rules -----

    // 1. Users & Memberships
    match /users/{userId} {
      allow get: if isSignedIn() && (userId == request.auth.uid || isAdmin());
      allow list: if isAdmin();
      allow create: if isSignedIn() && userId == request.auth.uid && isValidUser(incoming());
      allow update: if isSignedIn() && (
        (userId == request.auth.uid && incoming().diff(existing()).affectedKeys().hasOnly(['displayName', 'photoURL', 'mfaEnabled', 'biometricEnabled', 'lastLoginAt', 'activeTenantId'])) ||
        (isAdmin())
      );
      
      match /tenantMemberships/{tenantId} {
        allow read: if isSignedIn() && (userId == request.auth.uid || isAdmin());
        allow write: if isAdmin() || (userId == request.auth.uid && (isTenantAdmin(tenantId) || incoming().roleId == 'owner'));
      }

      // Notification preferences per tenant — only the user controls their own prefs
      match /notificationPrefs/{tenantId} {
        allow read: if isSignedIn() && (userId == request.auth.uid || isAdmin());
        allow write: if isSignedIn() && userId == request.auth.uid;
      }

      // FCM push tokens — user-owned, tenant-scoped
      match /fcmTokens/{tokenId} {
        allow read: if isSignedIn() && (userId == request.auth.uid || isAdmin());
        allow create, update: if isSignedIn() && userId == request.auth.uid;
        allow delete: if isSignedIn() && userId == request.auth.uid;
      }

      // Encrypted vault key backup — WORM: user writes once, only KMS CF can unwrap
      match /vaultBackup/{tenantId} {
        allow read: if isSignedIn() && userId == request.auth.uid;
        allow create, update: if isSignedIn() && userId == request.auth.uid;
        allow delete: if false;
      }
    }

    // 2. Tenants & Invitations
    match /tenants/{tenantId} {
      allow get: if isSignedIn() && (isMemberOf(tenantId) || isAdmin());
      allow list: if isAdmin();
      allow create: if isSignedIn() && (isValidTenant(incoming()) || isValidOnboardingTenant(incoming()));
      allow update: if isTenantAdmin(tenantId) &&
        incoming().diff(existing()).affectedKeys().hasOnly([
          'name', 'legalForm', 'vatNumber', 'settings', 'activeModules',
          'onboarding', 'onboardingDismissed', 'updatedAt',
          'ksefEnabled', 'zusEnabled', 'esgEnabled', 'hrEnabled', 'nip', 'country'
        ]);
      
      match /invitations/{invitationId} {
        allow get: if isSignedIn() && (isTenantAdmin(tenantId) || existing().email == request.auth.token.email);
        allow list: if isSignedIn() && (isTenantAdmin(tenantId));
        allow create: if isTenantAdmin(tenantId) && isValidTenantInvitation(incoming());
        allow update: if isTenantAdmin(tenantId) &&
          incoming().diff(existing()).affectedKeys().hasOnly(['status']);
        allow delete: if isAdmin();
      }

      match /chartOfAccounts/{docId} {
        allow read: if isSignedIn() && (isMemberOf(tenantId) || isAdmin());
        allow create, update, delete: if isTenantAdmin(tenantId);
      }

      match /journals/{docId} {
        allow read: if isSignedIn() && (isMemberOf(tenantId) || isAdmin());
        allow create, update, delete: if isTenantAdmin(tenantId);
      }

      match /costCenters/{docId} {
        allow read: if isSignedIn() && (isMemberOf(tenantId) || isAdmin());
        allow create, update, delete: if isTenantAdmin(tenantId);
      }

      match /signatures/{docId} {
        allow read: if isSignedIn() && (isMemberOf(tenantId) || isAdmin());
        allow create, update, delete: if isSignedIn() && isMemberOf(tenantId);
      }

      match /documents/{docId} {
        allow read: if isSignedIn() && (isMemberOf(tenantId) || isAdmin());
        allow create, update, delete: if isSignedIn() && isMemberOf(tenantId);
      }

      match /legalValidations/{docId} {
        allow read: if isSignedIn() && (isMemberOf(tenantId) || isAdmin());
        allow create, update, delete: if isSignedIn() && isMemberOf(tenantId);
      }

      match /integrations/{docId} {
        allow read: if isSignedIn() && (isTenantAdmin(tenantId) || isAdmin());
        allow create, update, delete: if isSignedIn() && isTenantAdmin(tenantId);
      }

      // Public API — keys, webhooks, logs
      match /api_keys/{keyId} {
        allow read: if isSignedIn() && (isTenantAdmin(tenantId) || isAdmin());
        allow create: if isSignedIn() && isTenantAdmin(tenantId);
        allow update: if isSignedIn() && isTenantAdmin(tenantId) &&
          incoming().diff(existing()).affectedKeys().hasOnly(['active', 'revokedAt', 'lastUsedAt']);
        allow delete: if false;
      }

      match /webhooks/{hookId} {
        allow read: if isSignedIn() && (isTenantAdmin(tenantId) || isAdmin());
        allow create, update, delete: if isSignedIn() && isTenantAdmin(tenantId);
      }

      match /api_logs/{logId} {
        allow read: if isSignedIn() && (isTenantAdmin(tenantId) || isAdmin());
        allow create: if isSignedIn() && isMemberOf(tenantId);
        allow update, delete: if false;
      }

      // Shop / E-commerce
      match /shop_products/{productId} {
        allow read: if isSignedIn() && (isMemberOf(tenantId) || isAdmin());
        allow create: if isSignedIn() && isTenantAdmin(tenantId);
        allow update, delete: if isSignedIn() && isTenantAdmin(tenantId);
      }

      match /shop_orders/{orderId} {
        allow read: if isSignedIn() && (isMemberOf(tenantId) || isAdmin());
        allow create: if isSignedIn() && isMemberOf(tenantId);
        allow update: if isSignedIn() && isTenantAdmin(tenantId) &&
          incoming().diff(existing()).affectedKeys().hasOnly(['status', 'updatedAt', 'notes']);
        allow delete: if false;
      }

      // Out-of-Pocket reimbursements
      match /reimbursements/{reimbId} {
        allow read: if isSignedIn() && (isMemberOf(tenantId) || isAdmin());
        allow create: if isSignedIn() && isMemberOf(tenantId);
        allow update: if isSignedIn() && isTenantAdmin(tenantId) &&
          incoming().diff(existing()).affectedKeys().hasOnly(['status', 'settledAt', 'paymentRef', 'updatedAt']);
        allow delete: if false;
      }

      // ── Workflow Module ────────────────────────────────────────────────────

      // Document instances — living documents in circulation
      match /documentInstances/{docId} {
        allow read: if isSignedIn() && isDocumentActor(tenantId, resource.data);
        allow list: if isSignedIn() && isMemberOf(tenantId);
        allow create: if isSignedIn() && isMemberOf(tenantId) &&
          incoming().tenantId == tenantId &&
          isValidDocumentInstance(incoming());
        // Updates only: transition fields — core identity fields are frozen
        allow update: if isSignedIn() &&
          isDocumentActor(tenantId, existing()) &&
          isValidDocumentInstanceUpdate(incoming(), existing());
        allow delete: if false; // Documents are never deleted — use ARCHIVED status
      }

      // Workflow step records — GoBD / GoBS append-only audit trail
      match /workflowSteps/{stepId} {
        allow read: if isSignedIn() && isMemberOf(tenantId);
        allow create: if isSignedIn() &&
          isMemberOf(tenantId) &&
          incoming().tenantId == tenantId &&
          isValidWorkflowStep(incoming());
        allow update, delete: if false; // STRICTLY IMMUTABLE — GoBD compliance
      }

      // Workflow templates — admin configures flow definitions per doc type
      match /workflowTemplates/{templateId} {
        allow read: if isSignedIn() && isMemberOf(tenantId);
        allow create: if isSignedIn() && isTenantAdmin(tenantId) &&
          isValidWorkflowTemplate(incoming());
        allow update: if isSignedIn() && isTenantAdmin(tenantId) &&
          incoming().diff(existing()).affectedKeys().hasOnly(['name', 'steps', 'isDefault', 'updatedAt', 'description']);
        allow delete: if isTenantAdmin(tenantId);
      }

      // In-app notifications — recipients read their own; members create
      match /notifications/{notifId} {
        allow read: if isSignedIn() && (
          resource.data.recipientId == request.auth.uid || isTenantAdmin(tenantId)
        );
        allow list: if isSignedIn() && isMemberOf(tenantId);
        allow create: if isSignedIn() && isMemberOf(tenantId) &&
          incoming().tenantId == tenantId &&
          isValidWorkflowNotification(incoming());
        allow update: if isSignedIn() &&
          existing().recipientId == request.auth.uid &&
          incoming().diff(existing()).affectedKeys().hasOnly(['read']); // only mark-as-read
        allow delete: if false;
      }

      // Denormalized role index for fast workflow actor resolution
      match /memberRoles/{docId} {
        allow read: if isSignedIn() && isMemberOf(tenantId);
        allow write: if isTenantAdmin(tenantId);
      }

      // Journal entries — accountant can create/read; WORM after posting (GoBD)
      match /journalEntries/{entryId} {
        allow read: if isSignedIn() && (isMemberOf(tenantId) || isAdmin());
        allow create: if isSignedIn() && isMemberOf(tenantId);
        allow update: if isSignedIn() && isTenantAdmin(tenantId) &&
          existing().status == 'DRAFT' &&
          incoming().diff(existing()).affectedKeys().hasOnly(['status', 'updatedAt']);
        allow delete: if false;
      }

      // ── Warehouse module (UC-WH-01..09) ─────────────────────────────────────

      match /warehouses/{warehouseId} {
        allow read: if isSignedIn() && isMemberOf(tenantId);
        allow create, update: if isTenantAdmin(tenantId);
        allow delete: if false;
      }

      match /warehouseProducts/{productId} {
        allow read: if isSignedIn() && isMemberOf(tenantId);
        allow create, update: if isTenantAdmin(tenantId);
        allow delete: if false;
      }

      match /stockMovements/{movId} {
        allow read: if isSignedIn() && isMemberOf(tenantId);
        allow create: if isSignedIn() && isMemberOf(tenantId);
        allow update: if isSignedIn() && isTenantAdmin(tenantId) &&
          existing().status == 'DRAFT' &&
          incoming().diff(existing()).affectedKeys().hasOnly(['status', 'confirmedBy', 'confirmedAt', 'cancelledBy', 'cancelledAt']);
        allow delete: if false;
      }

      match /stockLots/{lotId} {
        allow read: if isSignedIn() && isTenantAdmin(tenantId);
        allow create, update: if isTenantAdmin(tenantId);
        allow delete: if false;
      }

      match /inventoryCounts/{countId} {
        allow read: if isSignedIn() && isMemberOf(tenantId);
        allow create: if isSignedIn() && isMemberOf(tenantId);
        allow update: if isSignedIn() && isTenantAdmin(tenantId);
        allow delete: if false;
      }

      match /replenishmentAlerts/{alertId} {
        allow read: if isSignedIn() && isMemberOf(tenantId);
        allow create, update: if isTenantAdmin(tenantId);
        allow delete: if false;
      }

      // ── Grants module (UC-GR-01..06) ─────────────────────────────────────────

      match /grantProjects/{projId} {
        allow read: if isSignedIn() && isMemberOf(tenantId);
        allow create, update: if isTenantAdmin(tenantId);
        allow delete: if false;
      }

      match /grantCosts/{costId} {
        allow read: if isSignedIn() && isMemberOf(tenantId);
        allow create: if isSignedIn() && isMemberOf(tenantId);
        allow update: if isTenantAdmin(tenantId);
        allow delete: if false;
      }

      match /grantSettlements/{settlId} {
        allow read: if isSignedIn() && isMemberOf(tenantId);
        allow create, update: if isTenantAdmin(tenantId);
        allow delete: if false;
      }

      match /deMinimisEntries/{entryId} {
        allow read: if isSignedIn() && isMemberOf(tenantId);
        allow create: if isTenantAdmin(tenantId);
        allow update, delete: if false; // WORM — de minimis records are immutable
      }

      // ── K-Phase: financial compliance collections ─────────────────────────

      match /debtCases/{caseId} {
        allow read: if isSignedIn() && isMemberOf(tenantId);
        allow create, update: if isTenantAdmin(tenantId);
        allow delete: if false;
      }

      match /jpkReports/{reportId} {
        allow read: if isSignedIn() && isMemberOf(tenantId);
        allow create, update, delete: if false;
      }

      match /zusReports/{reportId} {
        allow read: if isSignedIn() && isMemberOf(tenantId);
        allow create, update, delete: if false;
      }

      match /certificates/{certId} {
        allow get: if isSignedIn() && (resource.data.userId == request.auth.uid || isTenantAdmin(tenantId));
        allow list: if isSignedIn() && isMemberOf(tenantId);
        allow create, update, delete: if false;
      }

      match /ksefInvoices/{invId} {
        allow read: if isSignedIn() && isMemberOf(tenantId);
        allow create, update, delete: if false;
      }

      match /bankTransactions/{txId} {
        allow read: if isSignedIn() && isMemberOf(tenantId);
        allow create, update, delete: if false;
      }

      match /esgReports/{reportId} {
        allow read: if isSignedIn() && isMemberOf(tenantId);
        allow create, update, delete: if false;
      }

      match /consolidationReports/{reportId} {
        allow read: if isSignedIn() && isTenantAdmin(tenantId);
        allow create, update, delete: if false;
      }

      match /fixedAssets/{assetId} {
        allow read: if isSignedIn() && isMemberOf(tenantId);
        allow create, update: if isTenantAdmin(tenantId);
        allow delete: if false;
      }

      match /pit11Reports/{reportId} {
        allow read: if isSignedIn() && isMemberOf(tenantId);
        allow create, update, delete: if false;
      }

      match /payslips/{payslipId} {
        allow read: if isSignedIn() && isMemberOf(tenantId);
        allow create: if isSignedIn() && isTenantAdmin(tenantId);
        allow update: if isSignedIn() && isTenantAdmin(tenantId);
        allow delete: if false;
      }

      match /gdprRequests/{reqId} {
        allow get: if isSignedIn() && (resource.data.subjectId == request.auth.uid || isTenantAdmin(tenantId));
        allow list: if isSignedIn() && isTenantAdmin(tenantId);
        allow create, update, delete: if false;
      }
    }

    // 3. Operational Data (Per-Tenant / Root with CompanyId Filter)
    
    match /hrSettings/{tenantId} {
      allow read: if isSignedIn() && (isTenantAdmin(tenantId) || isAdmin());
      allow write: if isTenantAdmin(tenantId) && isValidHRSettings(incoming());
    }

    match /employees/{empId} {
      allow get: if isSignedIn() && (isTenantAdmin(resource.data.tenantId) || isAdmin());
      allow list: if isSignedIn() && (isTenantAdmin(resource.data.tenantId) || isAdmin());
      allow create: if isSignedIn() && isTenantAdmin(incoming().tenantId) && isValidEmployee(incoming());
      allow update: if isSignedIn() && isTenantAdmin(existing().tenantId) && isValidEmployee(incoming());
    }

    match /leaves/{leaveId} {
      allow read: if isSignedIn() && (isTenantAdmin(resource.data.tenantId) || isAdmin());
      allow create: if isSignedIn() && isTenantAdmin(incoming().tenantId);
      allow update, delete: if isTenantAdmin(existing().tenantId);
    }

    match /projects/{projectId} {
      allow get: if isSignedIn() && (isMemberOf(existing().tenantId) || isAdmin());
      allow list: if isSignedIn() && (isMemberOf(resource.data.tenantId) || isAdmin());
      allow create: if isSignedIn() && isMemberOf(incoming().tenantId) && isTenantAdmin(incoming().tenantId);
      allow update: if isSignedIn() && isMemberOf(existing().tenantId) && isTenantAdmin(existing().tenantId) &&
        incoming().diff(existing()).affectedKeys().hasOnly(['name', 'status', 'description', 'updatedAt']) &&
        (incoming().get('updatedAt', request.time) == request.time);
    }

    match /timeEntries/{entryId} {
      allow get: if isSignedIn() && (isMemberOf(existing().tenantId) || isAdmin());
      allow list: if isSignedIn() && (isMemberOf(resource.data.tenantId) || isAdmin());
      allow create: if isSignedIn() && isMemberOf(incoming().tenantId) && incoming().userId == request.auth.uid;
      allow update: if isSignedIn() && (
        (existing().userId == request.auth.uid && incoming().diff(existing()).affectedKeys().hasOnly(['endTime', 'status', 'notes', 'updatedAt', 'endLocation'])) ||
        (isTenantAdmin(existing().tenantId))
      );
    }

    match /tasks/{taskId} {
      allow get: if isSignedIn() && (isMemberOf(existing().tenantId) || isAdmin());
      allow list: if isSignedIn() && (isMemberOf(resource.data.tenantId) || isAdmin());
      allow create: if isSignedIn() && isMemberOf(incoming().tenantId);
      allow update: if isSignedIn() && isMemberOf(existing().tenantId) &&
        incoming().diff(existing()).affectedKeys().hasOnly(['title', 'description', 'status', 'updatedAt']) &&
        (incoming().get('updatedAt', request.time) == request.time);
    }

    match /auditLogs/{logId} {
      allow read: if isTenantAdmin(resource.data.tenantId) || isAdmin();
      allow create: if isSignedIn() && isMemberOf(incoming().tenantId) && isValidAuditLog(incoming());
      allow update, delete: if false;
    }

    match /documents/{documentId} {
      allow read: if isSignedIn() && (isMemberOf(resource.data.tenantId) || isAdmin());
      allow create: if isSignedIn() && isMemberOf(incoming().tenantId) && isValidScanDocument(incoming());
      allow update, delete: if isSignedIn() && isTenantAdmin(existing().tenantId);
      
      match /versions/{versionId} {
        allow read: if isSignedIn() && (isMemberOf(get(/databases/$(database)/documents/documents/$(documentId)).data.tenantId) || isAdmin());
        allow create: if isSignedIn() && isMemberOf(get(/databases/$(database)/documents/documents/$(documentId)).data.tenantId) && isValidScanDocumentVersion(incoming());
        allow update, delete: if false; // immutable history
      }
    }

    match /payrolls/{payrollId} {
      allow get: if isSignedIn() && (
        isTenantAdmin(existing().tenantId) || 
        existing().userId == request.auth.uid || 
        (existing().managersAllowed.hasAny([request.auth.uid]))
      );
      allow list: if isSignedIn() && (
        isTenantAdmin(resource.data.tenantId) || 
        resource.data.userId == request.auth.uid || 
        (resource.data.managersAllowed.hasAny([request.auth.uid]))
      );
      allow create: if isTenantAdmin(incoming().tenantId);
      allow update, delete: if isTenantAdmin(existing().tenantId);
    }

    match /fleetItems/{fleetId} {
      allow read: if isSignedIn() && (isMemberOf(resource.data.tenantId) || isAdmin());
      allow create: if isTenantAdmin(incoming().tenantId);
      allow update, delete: if isTenantAdmin(existing().tenantId);

      match /photoHistory/{historyId} {
        allow read: if isSignedIn() && (isMemberOf(get(/databases/$(database)/documents/fleetItems/$(fleetId)).data.tenantId) || isAdmin());
        allow create, update, delete: if isTenantAdmin(get(/databases/$(database)/documents/fleetItems/$(fleetId)).data.tenantId);
      }
    }

    match /mediaEvidence/{mediaId} {
      allow read: if isSignedIn() && (isMemberOf(resource.data.tenantId) || existing().userId == request.auth.uid || isAdmin());
      allow create: if isSignedIn() && isMemberOf(incoming().tenantId);
      allow update, delete: if isTenantAdmin(existing().tenantId);
    }

    match /payments/{paymentId} {
      allow get: if isSignedIn() && (isMemberOf(resource.data.tenantId) || resource.data.userId == request.auth.uid || isAdmin());
      allow list: if isSignedIn() && (isMemberOf(resource.data.tenantId) || isAdmin());
      allow create: if isSignedIn() && isMemberOf(incoming().tenantId);
      allow update: if isSignedIn() && isTenantAdmin(existing().tenantId);
      allow delete: if false;
    }

    match /clients/{clientId} {
      allow read: if isSignedIn() && (isMemberOf(resource.data.tenantId) || isAdmin());
      allow create: if isTenantAdmin(incoming().tenantId);
      allow update, delete: if isTenantAdmin(existing().tenantId);
    }

    match /services/{serviceId} {
      allow read: if isSignedIn() && (isMemberOf(resource.data.tenantId) || isAdmin());
      allow create: if isSignedIn() && isMemberOf(incoming().tenantId);
      allow update: if isTenantAdmin(existing().tenantId);
    }

    match /customers/{custId} {
      allow read: if isSignedIn() && (isMemberOf(resource.data.tenantId) || isAdmin());
      allow create: if isSignedIn() && isMemberOf(incoming().tenantId) && isValidCustomer(incoming());
      allow update, delete: if isSignedIn() && isTenantAdmin(existing().tenantId);
    }

    match /deals/{dealId} {
      allow read: if isSignedIn() && (isMemberOf(resource.data.tenantId) || isAdmin());
      allow create: if isSignedIn() && isMemberOf(incoming().tenantId) && isValidDeal(incoming());
      allow update, delete: if isSignedIn() && isMemberOf(existing().tenantId);
    }

    match /quotes/{quoteId} {
      allow read: if isSignedIn() && (isMemberOf(resource.data.tenantId) || isAdmin());
      allow create: if isSignedIn() && isMemberOf(incoming().tenantId) && isValidQuote(incoming());
      allow update, delete: if isSignedIn() && isMemberOf(existing().tenantId);
    }

    // 4. Compliance & Payments
    match /riskAssessments/{riskId} {
      allow read: if isSignedIn() && (isTenantAdmin(resource.data.tenantId) || isAdmin());
      allow create: if isSignedIn() && isTenantAdmin(incoming().tenantId) && isValidRiskAssessment(incoming());
      allow update: if isSignedIn() && isTenantAdmin(existing().tenantId) && isValidRiskAssessment(incoming());
    }

    match /paymentTransactions/{txId} {
      allow get: if isSignedIn() && (resource.data.customerId == request.auth.uid || isAdmin());
      allow list: if isSignedIn() && (resource.data.customerId == request.auth.uid || isAdmin());
      allow create: if isSignedIn() && (incoming().customerId == request.auth.uid || isAdmin()) && isValidPaymentTransaction(incoming());
      allow update: if isAdmin();
    }

    match /subscriptions/{subId} {
      allow read: if isSignedIn() && (resource.data.customerId == request.auth.uid || isAdmin());
      allow create, update: if isAdmin();
    }

    // 5. Cross-Company & Advisory
    match /oauthSecrets/{secretId} {
      allow read, write: if isAdmin(); // Only super-admins can touch secrets vault
    }

    match /crossTenantTransactions/{txId} {
      allow read: if isSignedIn() && (isTenantAdmin(resource.data.sourceTenantId) || isTenantAdmin(resource.data.targetTenantId) || isAdmin());
      allow create: if isSignedIn() && isTenantAdmin(incoming().sourceTenantId) && isValidCrossTenantTransaction(incoming());
      allow update: if isSignedIn() && (isTenantAdmin(existing().targetTenantId) || isTenantAdmin(existing().sourceTenantId) || isAdmin());
    }

    match /transactionCategories/{categoryId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && isTenantAdmin(incoming().createdByTenantId) && isValidTransactionCategory(incoming());
      allow update: if isSignedIn() && isTenantAdmin(existing().createdByTenantId) && isValidTransactionCategory(incoming());
      allow delete: if isSignedIn() && isTenantAdmin(existing().createdByTenantId);
    }
    
    match /businessProcesses/{processId} {
      allow read: if isSignedIn() && (isMemberOf(resource.data.tenantId) || isAdmin());
      allow create: if isSignedIn() && isComplianceManager(incoming().tenantId) && isValidBusinessProcess(incoming());
      allow update: if isSignedIn() && isComplianceManager(existing().tenantId) && isValidBusinessProcess(incoming());
      allow delete: if isSignedIn() && isComplianceManager(existing().tenantId);
    }

    match /aiSystems/{systemId} {
      allow read: if isSignedIn() && (isMemberOf(resource.data.tenantId) || isAdmin());
      allow create: if isSignedIn() && isComplianceManager(incoming().tenantId) && isValidAiSystem(incoming());
      allow update: if isSignedIn() && isComplianceManager(existing().tenantId) && isValidAiSystem(incoming());
      allow delete: if isSignedIn() && isComplianceManager(existing().tenantId);
    }
    
    match /auditFormTemplates/{templateId} {
      allow read: if isSignedIn() && (isMemberOf(resource.data.tenantId) || isAdmin());
      allow create: if isSignedIn() && isSafetyManager(incoming().tenantId) && isValidAuditFormTemplate(incoming());
      allow update: if isSignedIn() && isSafetyManager(existing().tenantId) && isValidAuditFormTemplate(incoming());
      allow delete: if isSignedIn() && isSafetyManager(existing().tenantId);
    }

    match /auditFormSubmissions/{submissionId} {
      allow read: if isSignedIn() && (isMemberOf(resource.data.tenantId) || isAdmin());
      allow create: if isSignedIn() && isMemberOf(incoming().tenantId) && isValidAuditFormSubmission(incoming());
      allow update: if isSignedIn() && isMemberOf(existing().tenantId) && isValidAuditFormSubmission(incoming());
      allow delete: if isSignedIn() && isSafetyManager(existing().tenantId);
    }

    match /tpDocuments/{docId} {
      allow read: if isSignedIn() && (isTenantAdmin(resource.data.tenantId) || isAdmin());
      allow create: if isSignedIn() && isTenantAdmin(incoming().tenantId) && isValidTPDocument(incoming());
      allow update: if isSignedIn() && isTenantAdmin(existing().tenantId) && isValidTPDocument(incoming());
    }

    match /complianceScoreHistory/{docId} {
      allow read: if isSignedIn() && (isTenantAdmin(resource.data.tenantId) || isAdmin());
      allow create: if isSignedIn() && isTenantAdmin(incoming().tenantId);
      allow update, delete: if false;
    }

    match /integrations/{integrationId} {
      allow read: if isSignedIn() && (isTenantAdmin(resource.data.tenantId) || isAdmin());
      allow create: if isSignedIn() && isTenantAdmin(incoming().tenantId) && isValidIntegration(incoming());
      allow update: if isSignedIn() && isTenantAdmin(existing().tenantId) && (
        incoming().diff(existing()).affectedKeys().hasOnly(['config', 'status', 'lastSyncedAt'])
      );
      allow delete: if isSignedIn() && isTenantAdmin(existing().tenantId);
    }
    
    match /invitations/{invitationId} {
      allow read: if isSignedIn() && (isTenantAdmin(resource.data.tenantId) || resource.data.email == request.auth.token.email || isAdmin());
      allow create: if isSignedIn() && isTenantAdmin(incoming().tenantId);
      allow update: if isSignedIn() && isTenantAdmin(existing().tenantId);
      allow delete: if isAdmin() || (isSignedIn() && isTenantAdmin(existing().tenantId));
    }
    
    match /aiConversations/{conversationId} {
      allow read: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isSignedIn() && isValidAIConversation(incoming());
      allow update: if isSignedIn() && resource.data.userId == request.auth.uid && (
        incoming().diff(existing()).affectedKeys().hasOnly(['status', 'updatedAt'])
      );
      
      match /auditLogs/{logId} {
        allow read: if isSignedIn() && (get(/databases/$(database)/documents/aiConversations/$(conversationId)).data.userId == request.auth.uid || isAdmin());
        allow create: if isSignedIn() && isValidAIConversationAudit(incoming());
      }
    }

    // 6. System Metadata
    match /systemModules/{moduleId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    match /system_config/{configId} {
      allow read: if isSignedIn() && (
        isAdmin() || 
        (configId.matches('^audit_.*') && isTenantAdmin(configId.replace('^audit_(retention_)?', ''))) || 
        configId == 'security_policies'
      );
      allow write: if isSignedIn() && (
        isAdmin() || 
        (configId.matches('^audit_.*') && isTenantAdmin(configId.replace('^audit_(retention_)?', ''))) || 
        (configId == 'security_policies' && isAdmin())
      );
    }

    match /system_logs/{logId} {
      allow read: if true;
      allow write: if false;
    }

    match /industries/{industryId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }
    
    match /financialTransactions/{txId} {
      allow read: if isSignedIn() && (isMemberOf(resource.data.tenantId) || isAdmin());
      allow create: if isSignedIn() && isMemberOf(incoming().tenantId);
      allow update, delete: if isSignedIn() && isTenantAdmin(existing().tenantId);
    }
    
    match /invoices/{invoiceId} {
      allow read: if isSignedIn() && (isMemberOf(resource.data.tenantId) || isAdmin());
      allow create: if isSignedIn() && isMemberOf(incoming().tenantId);
      allow update, delete: if isSignedIn() && isTenantAdmin(existing().tenantId);
    }
    
    match /transactions/{txId} {
      allow read: if isSignedIn() && (isMemberOf(resource.data.tenantId) || isAdmin());
      allow create: if isSignedIn() && isMemberOf(incoming().tenantId);
      allow update, delete: if isSignedIn() && isTenantAdmin(existing().tenantId);
    }
    
    match /costCenters/{ccId} {
      allow read: if isSignedIn() && (isMemberOf(resource.data.tenantId) || isAdmin());
      allow create: if isSignedIn() && isTenantAdmin(incoming().tenantId);
      allow update, delete: if isSignedIn() && isTenantAdmin(existing().tenantId);
    }

    match /roles/{roleId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    // ── Multi-Company: companies collection ──────────────────────────────────
    // Access: member of the tenant can read; ADMIN/OWNER of the tenant can write.
    // Hard delete is forbidden — use isActive = false (soft delete).

    match /companies/{companyId} {
      allow get: if isSignedIn() && (isMemberOf(resource.data.tenantId) || isAdmin());
      allow list: if isSignedIn();  // filtered client-side by tenantId query
      allow create: if isSignedIn() &&
        isValidCompany(incoming()) &&
        incoming().createdAt == request.time &&
        (isTenantAdmin(incoming().tenantId) || isTenantOwnerBootstrap(incoming().tenantId));
      allow update: if isSignedIn() &&
        isTenantAdmin(existing().tenantId) &&
        isValidCompanyUpdate(incoming(), existing());
      allow delete: if false;  // use isActive = false
    }

    // ── Multi-Company: flat tenantMemberships (admin-view listing) ────────────
    // This flat collection mirrors users/{uid}/tenantMemberships subcollection.
    // Security is gated by the subcollection check (isMemberOf / isTenantAdmin).
    // Members read the list; ADMIN/OWNER write (invite / role change / remove).

    match /tenantMemberships/{membershipId} {
      allow get: if isSignedIn() && (isMemberOf(resource.data.tenantId) || isAdmin());
      allow list: if isSignedIn();  // filtered client-side by tenantId query
      allow create: if isSignedIn() &&
        isValidTenantMembershipFlat(incoming()) &&
        (isTenantAdmin(incoming().tenantId) || isOnboardingOwnerMembership(membershipId));
      allow update: if isSignedIn() &&
        isTenantAdmin(existing().tenantId) &&
        incoming().tenantId == existing().tenantId &&
        incoming().diff(existing()).affectedKeys().hasOnly(['role', 'status', 'displayName', 'userId', 'companies']);
      allow delete: if isSignedIn() && isTenantAdmin(existing().tenantId);
    }

    // ── HR: flat collections with tenantId field ─────────────────────────────

    match /hr_departments/{deptId} {
      allow get: if isSignedIn() && (isMemberOf(resource.data.tenantId) || isAdmin());
      allow list: if isSignedIn();  // filtered client-side by tenantId query
      allow create: if isSignedIn() &&
        isValidHrDepartment(incoming()) &&
        (isTenantAdmin(incoming().tenantId) || isTenantOwnerBootstrap(incoming().tenantId));
      allow update: if isSignedIn() &&
        isTenantAdmin(existing().tenantId) &&
        incoming().tenantId == existing().tenantId &&
        incoming().diff(existing()).affectedKeys().hasOnly(['name', 'type', 'parentId', 'managerId', 'updatedAt']);
      allow delete: if isSignedIn() && isTenantAdmin(existing().tenantId);
    }

    match /hr_roles/{roleId} {
      allow get: if isSignedIn() && (isMemberOf(resource.data.tenantId) || isAdmin());
      allow list: if isSignedIn();
      allow create, update, delete: if isSignedIn() && isTenantAdmin(incoming().tenantId);
    }

    match /tenantGroups/{groupId} {
      allow read: if isSignedIn() && isAdmin();
      allow create, update: if isAdmin();
      allow delete: if false;
    }

    // Firebase Trigger Email extension queue — signed-in users can enqueue
    match /mail/{mailId} {
      allow read: if isAdmin();
      allow create: if isSignedIn();
      allow update, delete: if false;
    }
  }
}
