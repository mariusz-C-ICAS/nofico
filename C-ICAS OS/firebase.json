{
  "functions": {
    "source": "functions",
    "runtime": "nodejs20"
  },
  "firestore": {
    "rules": "firestore.rules"
  },
  "hosting": {
    "site": "app-c-icas-os",
    "public": "dist",
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**"
    ],
    "headers": [
      {
        "source": "**",
        "headers": [
          { "key": "Cross-Origin-Opener-Policy", "value": "same-origin-allow-popups" }
        ]
      }
    ],
    "rewrites": [
      { "source": "/api/stripe/checkout", "function": "stripeCheckout" },
      { "source": "/api/stripe/webhook", "function": "stripeWebhook" },
      { "source": "/api/tink/init", "function": "tinkInitPayment" },
      { "source": "/api/tink/webhook", "function": "tinkPaymentWebhook" },
      { "source": "/payment-callback", "destination": "/payment-callback.html" },
      { "source": "**", "destination": "/index.html" }
    ]
  }
}
